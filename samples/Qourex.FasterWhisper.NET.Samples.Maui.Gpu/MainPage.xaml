<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Qourex.FasterWhisper.NET.Samples.Maui.Gpu.MainPage"
             BackgroundColor="#0F172A">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Title Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,15">
            <Label Text="FasterWhisper.NET - GPU (CUDA)" 
                   TextColor="White" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />
            <Label Text="GPU-Accelerated Speech-to-Text Transcription" 
                   TextColor="#94A3B8" 
                   FontSize="14" 
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Main Body Grid: Settings & Results -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 1.5*" ColumnSpacing="15">
            <!-- Left: Settings Panel -->
            <ScrollView Grid.Column="0">
                <VerticalStackLayout Spacing="15">
                    <Border StrokeShape="RoundRectangle 12" Stroke="rgba(255,255,255,0.08)" BackgroundColor="#1E293B" Padding="15">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Settings" TextColor="White" FontSize="16" FontAttributes="Bold" />

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Model Size" TextColor="#CBD5E1" FontSize="12" />
                                <Picker x:Name="ModelPicker" Title="Select model" TextColor="White" TitleColor="#64748B">
                                    <Picker.Items>
                                        <x:String>tiny</x:String>
                                        <x:String>base</x:String>
                                        <x:String>small</x:String>
                                    </Picker.Items>
                                    <Picker.SelectedIndex>0</Picker.SelectedIndex>
                                </Picker>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="Audio Preset" TextColor="#CBD5E1" FontSize="12" />
                                <HorizontalStackLayout Spacing="10">
                                    <Button Text="harvard.wav" Clicked="OnSelectPreset1" BackgroundColor="#334155" TextColor="White" WidthRequest="110" HeightRequest="40" Padding="5"/>
                                    <Button Text="harvard2.wav" Clicked="OnSelectPreset2" BackgroundColor="#334155" TextColor="White" WidthRequest="110" HeightRequest="40" Padding="5"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Button Text="Or Pick WAV File" Clicked="OnPickFileClicked" BackgroundColor="#475569" TextColor="White" Margin="0,5,0,0" HeightRequest="45" />
                            <Label x:Name="SelectedFileLabel" Text="Selected: harvard.wav" TextColor="#94A3B8" FontSize="11" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <Button x:Name="TranscribeBtn" Text="Transcribe (CUDA) ⚡" Clicked="OnTranscribeClicked" BackgroundColor="#4F46E5" TextColor="White" FontAttributes="Bold" HeightRequest="50" />
                    
                    <VerticalStackLayout x:Name="ProgressLayout" IsVisible="False" Spacing="5">
                        <Label x:Name="ProgressLabel" Text="Downloading..." TextColor="#E2E8F0" FontSize="12" />
                        <ProgressBar x:Name="ProgressIndicator" Progress="0" ProgressColor="#6366F1" HeightRequest="8" />
                    </VerticalStackLayout>

                    <Label x:Name="StatusLabel" Text="Ready" TextColor="#34D399" FontSize="13" FontAttributes="Italic" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </ScrollView>

            <!-- Right: Results Panel -->
            <Border Grid.Column="1" StrokeShape="RoundRectangle 12" Stroke="rgba(255,255,255,0.08)" BackgroundColor="#1E293B" Padding="15">
                <Grid RowDefinitions="Auto, *">
                    <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Fill" Spacing="15" Margin="0,0,0,10">
                        <Label Text="Transcript Output" TextColor="White" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" />
                        <Label x:Name="TimeLabel" Text="" TextColor="#34D399" FontSize="12" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                    
                    <CollectionView Grid.Row="1" x:Name="SegmentsListView">
                        <CollectionView.EmptyView>
                            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                <Label Text="📝" FontSize="36" HorizontalOptions="Center" Opacity="0.5" />
                                <Label Text="Press Transcribe to decode speech." TextColor="#64748B" FontSize="13" HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <VerticalStackLayout Padding="10" Spacing="5">
                                    <Label Text="{Binding TimeRange}" TextColor="#818CF8" FontSize="11" FontAttributes="Bold" />
                                    <Label Text="{Binding Text}" TextColor="#E2E8F0" FontSize="13" LineBreakMode="WordWrap" />
                                    <BoxView HeightRequest="1" Color="rgba(255,255,255,0.05)" Margin="0,5,0,0" />
                                </VerticalStackLayout>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Label Grid.Row="2" Text="Powered by FasterWhisper.NET" TextColor="#475569" FontSize="11" HorizontalOptions="Center" Margin="0,10,0,0" />
    </Grid>

</ContentPage>
